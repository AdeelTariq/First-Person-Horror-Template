; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="First Person Horror Template"
config/tags=PackedStringArray("starterkit")
run/main_scene="res://scenes/menus/opening/opening_with_logo.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

AppConfig="*uid://cjke6crjg14a0"
SceneLoader="*uid://cbwmrnp0af35y"
ProjectMusicController="*uid://r5t485lr3p7t"
ProjectUISoundController="*uid://cc37235kj4384"
InputIconMapperGlobal="*uid://done0t0ojxyp1"
GamePiecesEventBus="*uid://cm31gl2cxmt6y"
SoundFxMgr="*res://scenes/sound_fx/sound_fx_mgr.tscn"
Talo="*uid://cf5txmco4tia4"
TaloGlobal="*res://scripts/talo_events.gd"
co="*uid://bjkb7sfgdaofj"
ImpactMgr="*uid://dsun3ccikxe7v"
SceneRenderManager="*uid://mbume3uiijsw"

[debug]

gdscript/warnings/untyped_declaration=1
gdscript/warnings/inferred_declaration=1
gdscript/warnings/unsafe_property_access=1
gdscript/warnings/unsafe_method_access=1
gdscript/warnings/unsafe_cast=1
gdscript/warnings/unsafe_call_argument=1

[display]

window/size/mode=3
window/vsync/vsync_mode=2

[editor]

movie_writer/movie_file="/home/adeel/Videos/fpht.avi"

[editor_plugins]

enabled=PackedStringArray("res://addons/apply_material_menu/plugin.cfg", "res://addons/brackeys_particle_controls/plugin.cfg", "res://addons/co/plugin.cfg", "res://addons/credits_generator/plugin.cfg", "res://addons/game_pieces/plugin.cfg", "res://addons/hl_impacts/plugin.cfg", "res://addons/maaacks_menus_template/plugin.cfg", "res://addons/prompt_formatters/plugin.cfg", "res://addons/proton_scatter/plugin.cfg", "res://addons/scene_texture/plugin.cfg", "res://addons/sound_fx_manager/plugin.cfg", "res://addons/talo/plugin.cfg")

[file_customization]

folder_colors={
"res://addons/": "blue",
"res://assets/": "orange",
"res://resources/": "red",
"res://scenes/": "pink",
"res://scripts/": "gray",
"res://shaders/": "purple"
}

[impact_manager]

auto_load_path="res://scenes/impacts/"

